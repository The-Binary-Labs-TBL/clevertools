__pycache__/
*.py[cod]
*$py.class
*.py,cover

# Virtual environments
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/
python/.venv/
python/venv/
python/env/

# Packaging / distribution
.Python
develop-eggs/
downloads/
eggs/
.eggs/
pip-wheel-metadata/
share/python-wheels/
*.egg
*.egg-info/
