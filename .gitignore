# ============================================================
# Global / repository-wide ignore rules
# ============================================================
# Goal:
# - cover the vast majority of local-only, generated, cached and
#   machine-specific files
# - stay readable and maintainable
# - support Python, Rust, editors, build tooling and common CI/dev flows
#
# Notes:
# - Rules here do NOT remove already tracked files from git history.
# - Keep lockfiles only if your workflow requires them versioned.
# - If a specific generated file should be committed, add an explicit `!path`.


# ============================================================
# OS / filesystem noise
# ============================================================
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
.fseventsd
Icon?
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
ehthumbs.db
*.lnk


# ============================================================
# Temporary files, backups, swap files
# ============================================================
*.tmp
*.temp
*.bak
*.orig
*.rej
*.swp
*.swo
*.swn
*.seed
*.pid
*.pid.lock
*.stackdump
*~


# ============================================================
# Logs, dumps, traces
# ============================================================
*.log
*.log.*
logs/
log/
*.out
*.err
*.trace
*.dmp
*.dump
*.core
core
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*


# ============================================================
# Secrets, local env files, machine-local overrides
# ============================================================
.env
.env.*
.envrc
.direnv/
*.local
*.secret
*.secrets
*.credentials

# Common examples that are usually safe to keep
!.env.example
!.env.sample
!.env.template


# ============================================================
# Git artifacts, patches, merge leftovers
# ============================================================
# `.git/` itself is intentionally NOT listed here.
# In a normal repository it would not be useful to ignore it.
*.patch
*.diff
*.orig
*.BASE.*
*.LOCAL.*
*.REMOTE.*
*.BACKUP.*
*.BASE
*.LOCAL
*.REMOTE
*.BACKUP

# Local Git helper files occasionally created by tooling/scripts
.gitmodules.local
.gitconfig.local
.git-credentials
.git-credential-cache/
.git-assume-unchanged
.git-skip-worktree


# ============================================================
# Editors / IDEs
# ============================================================
.idea/
.fleet/
.vs/
.project
.classpath
.settings/
.metadata/
*.iml
*.ipr
*.iws
*.suo
*.user
*.userossc
*.rsuser
*.sln.docstates
*.code-workspace
*.tmproj
Session.vim

# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets

# Local editor history / helper state
.history/
.ionide/
.vscode-test/
.nova/
.zed/
.cursor/
.codeium/
.windsurf/
.idea_modules/


# ============================================================
# Generic caches and tool state
# ============================================================
.cache/
.eslintcache
.stylelintcache
.sass-cache/
.parcel-cache/
.tmp/
tmp/
temp/
.DSC_Store


# ============================================================
# Archives / packaged artifacts
# ============================================================
*.7z
*.bz2
*.gz
*.rar
*.tar
*.tgz
*.xz
*.zip


# ============================================================
# Generic binaries / compiled artifacts
